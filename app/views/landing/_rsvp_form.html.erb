<div id="rsvp-form" class="rsvp-form">
  <% if defined?(success_message) && success_message %>
    <div class="rsvp-form__success">
      <%= success_message %>

      <%= dev_tool do %>
        <div>
          <%= link_to "Open your letter opener", "/letter_opener", target: "_blank" %>
        </div>
      <% end %>
    </div>
  <% elsif defined?(error_message) && error_message %>
    <div class="rsvp-form__error">
      <%= error_message %>
    </div>
  <% end %>

  <% unless defined?(success_message) && success_message %>
    <%= form_with model: rsvp || Rsvp.new, url: rsvps_path, local: false, class: "rsvp-form__row" do |form| %>
      <%= hidden_field_tag :ref, params[:ref] %>
      <%= form.email_field :email, placeholder: "jebediah@hackclub.com", autocomplete: "off", class: "rsvp-form__input" %>
      <%= form.button type: "submit", class: "rsvp-form__submit" do %>
        RSVP &rarr;
      <% end %>
    <% end %>
  <% end %>
</div>

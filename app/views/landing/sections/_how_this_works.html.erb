<section class="how-it-works">
  <%= image_tag "landing/space/nebula-bg.png", class: "how-it-works__bg", alt: "", aria_hidden: "true" %>

  <h2 class="how-it-works__heading">How it works</h2>

  <div class="how-it-works__cards">
    <div class="how-it-works__card-wrapper how-it-works__card-wrapper--1">
      <div class="how-it-works__card">
        <h3 class="how-it-works__card-title">Build projects</h3>
        <p class="how-it-works__card-body">Build websites, games, apps, electronics, or any other open-source project that can be shared to showcase your skill.</p>
      </div>
    </div>

    <div class="how-it-works__card-wrapper how-it-works__card-wrapper--2">
      <div class="how-it-works__card">
        <h3 class="how-it-works__card-title">Earn prizes</h3>
        <p class="how-it-works__card-body">Redeem your stars for awesome prizes like raspberry pis, server hosting, 3d printers, and more to fuel your next creation.</p>
      </div>
    </div>
  </div>
</section>

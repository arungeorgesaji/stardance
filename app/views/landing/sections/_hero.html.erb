<section class="hero" role="main">
  <div class="hero__bg" aria-hidden="true">
    <%= image_tag "landing/space/moon-opp.png", class: "hero__bg-overlay", alt: "" %>
  </div>

  <nav class="hero__nav">
    <%= image_tag "landing/space/stardance.png", class: "hero__nav-logo", alt: "Stardance Challenge" %>
    <div class="hero__nav-sponsors">
      <%= image_tag "landing/space/hackclub.png", alt: "Hack Club", class: "hero__nav-sponsor" %>
      <span class="hero__nav-sponsor-divider" aria-hidden="true">|</span>
      <%= image_tag "landing/space/nasa.png", alt: "NASA", class: "hero__nav-sponsor" %>
      <span class="hero__nav-sponsor-divider" aria-hidden="true">|</span>
      <%= image_tag "landing/space/amd.png", alt: "AMD", class: "hero__nav-sponsor hero__nav-sponsor--amd" %>
    </div>
  </nav>

  <div class="hero__content">
    <p class="hero__eyebrow">For teens (13&ndash;18):</p>
    <h1 class="hero__heading">Build something out of this world.</h1>
    <p class="hero__subtext">The largest STEM challenge of the summer &mdash; code personal projects and win free prizes.</p>

    <div class="hero__rsvp">
      <%= render "landing/rsvp_form", rsvp: nil %>
    </div>

    <p class="hero__disclaimer"><em>For all teens aged 13&ndash;18.</em></p>
  </div>

  <div class="hero__art" aria-hidden="true">
    <div class="hero__art-photo hero__art-photo--top">
      <%= image_tag "landing/space/juice.png", alt: "", class: "hero__art-photo-img" %>
    </div>
    <div class="hero__art-photo hero__art-photo--bottom">
      <%= image_tag "landing/space/reem.png", alt: "", class: "hero__art-photo-img" %>
    </div>
    <%= image_tag "landing/space/val's-probe.png", class: "hero__art-spacecraft", alt: "" %>
    <%= image_tag "landing/space/jeb's-station.png", class: "hero__art-satellite", alt: "" %>
  </div>
</section>

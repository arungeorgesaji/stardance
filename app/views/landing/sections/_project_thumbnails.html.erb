<div class="project-thumbs-section">
  <%= image_tag image_url("landing/projects/decorative-curve.svg"), class: "project-thumbs-section__curve", alt: "", aria: { hidden: true }, loading: "lazy" %>

  <div class="project-thumbs-section__step">
    <h3 class="project-thumbs-section__step-heading">1. Make projects</h3>
    <p class="project-thumbs-section__step-lead">Build any website, game, app, hardware of your liking. No experience required.</p>
  </div>

  <div class="project-thumbs" aria-label="Past projects by teens">
    <%= link_to "https://shaaarkai.itch.io/specter", class: "project-thumbs__item project-thumbs__item--1", target: "_blank", rel: "noopener noreferrer" do %>
      <div class="project-thumbs__tab">By Yessa, 18</div>
      <div class="project-thumbs__img-wrap">
        <%= image_tag image_url("landing/projects/yessa.png"), class: "project-thumbs__img", alt: "Project by Yessa", loading: "lazy" %>
      </div>
      <div class="project-thumbs__desc" aria-hidden="true">A knight bravely attempts to escape a haunted cave while pursued by his own ghost.</div>
    <% end %>

    <%= link_to "https://github.com/Dieu-de-l-elec/AngstromIO-devboard", class: "project-thumbs__item project-thumbs__item--2", target: "_blank", rel: "noopener noreferrer" do %>
      <div class="project-thumbs__tab">By Cl&eacute;ment, 17</div>
      <div class="project-thumbs__img-wrap">
        <%= image_tag image_url("landing/projects/clement.png"), class: "project-thumbs__img", alt: "Project by Clément", loading: "lazy" %>
      </div>
      <div class="project-thumbs__desc" aria-hidden="true">A pocket‑sized, custom Attiny1616 devboard, with two GPIOs and I2C, a dual‑CH340 UPDI programmer!</div>
    <% end %>

    <%= link_to "https://github.com/geg-tech/brew-keeb", class: "project-thumbs__item project-thumbs__item--3", target: "_blank", rel: "noopener noreferrer" do %>
      <div class="project-thumbs__tab">By Alexander, 16</div>
      <div class="project-thumbs__img-wrap">
        <%= image_tag image_url("landing/projects/alexander.png"), class: "project-thumbs__img", alt: "Project by Alexander", loading: "lazy" %>
      </div>
      <div class="project-thumbs__desc" aria-hidden="true">A fully documented, custom keyboard with built-in RGB, OLED and a USB hub made for Blueprint!</div>
    <% end %>

    <%= link_to "https://deltea.itch.io/starbird", class: "project-thumbs__item project-thumbs__item--4", target: "_blank", rel: "noopener noreferrer" do %>
      <div class="project-thumbs__tab">By Deltea, 16</div>
      <div class="project-thumbs__img-wrap">
        <%= image_tag image_url("landing/projects/deltea.png"), class: "project-thumbs__img", alt: "Project by Deltea", loading: "lazy" %>
      </div>
      <div class="project-thumbs__desc" aria-hidden="true">A platformer game about a bird collecting stars, made for Milkyway!</div>
    <% end %>

    <%= link_to "https://github.com/SteveMan67/platformed", class: "project-thumbs__item project-thumbs__item--5", target: "_blank", rel: "noopener noreferrer" do %>
      <div class="project-thumbs__tab">By Steve, 16</div>
      <div class="project-thumbs__img-wrap">
        <%= image_tag image_url("landing/projects/steve.png"), class: "project-thumbs__img", alt: "Project by Steve", loading: "lazy" %>
      </div>
      <div class="project-thumbs__desc" aria-hidden="true">A platformer with a fully functioning level editor, online level sharing, and trigger system, built from the ground up in Javascript for Flavortown.</div>
    <% end %>
  </div>

  <div class="project-thumbs-section__new-to-coding">
    <p class="project-thumbs-section__ntc-title">New to coding?</p>
    <p class="project-thumbs-section__ntc-body">No fear &mdash; we have guides for complete beginners!</p>
  </div>
</div>

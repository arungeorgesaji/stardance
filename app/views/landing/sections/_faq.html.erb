<section class="faq-section" data-controller="faq-accordion">
  <h2 class="faq-section__title">FAQ</h2>

  <div class="faq-section__list">
    <div class="faq-section__item" data-action="click->faq-accordion#toggle">
      <span class="faq-section__number">1.</span>
      <span class="faq-section__question">Who is eligible?</span>
      <span class="faq-section__arrow" data-faq-accordion-target="arrow">&#9654;</span>
      <div class="faq-section__answer" data-faq-accordion-target="answer">
        Stardance is for highschoolers! You need to be 13-18 years old to participate.
      </div>
    </div>
    <div class="faq-section__item" data-action="click->faq-accordion#toggle">
      <span class="faq-section__number">2.</span>
      <span class="faq-section__question">How much does it cost?</span>
      <span class="faq-section__arrow" data-faq-accordion-target="arrow">&#9654;</span>
      <div class="faq-section__answer" data-faq-accordion-target="answer">
        100% free* - all the prizes are donated to us or paid for by us!<br>
        *customs might occur outside of the US
      </div>
    </div>
    <div class="faq-section__item" data-action="click->faq-accordion#toggle">
      <span class="faq-section__number">3.</span>
      <span class="faq-section__question">What types of projects count?</span>
      <span class="faq-section__arrow" data-faq-accordion-target="arrow">&#9654;</span>
      <div class="faq-section__answer" data-faq-accordion-target="answer">
        All kinds of technical projects as long as it&rsquo;s open-source!
      </div>
    </div>
    <div class="faq-section__item" data-action="click->faq-accordion#toggle">
      <span class="faq-section__number">4.</span>
      <span class="faq-section__question">How many projects can I build?</span>
      <span class="faq-section__arrow" data-faq-accordion-target="arrow">&#9654;</span>
      <div class="faq-section__answer" data-faq-accordion-target="answer">
        There&rsquo;s no limit! Cook as much as you can!
      </div>
    </div>
    <div class="faq-section__item" data-action="click->faq-accordion#toggle">
      <span class="faq-section__number">5.</span>
      <span class="faq-section__question">Is this legit?</span>
      <span class="faq-section__arrow" data-faq-accordion-target="arrow">&#9654;</span>
      <div class="faq-section__answer" data-faq-accordion-target="answer">
        Yup! Last winter we ran Flavortown, and before that we ran Summer of Making&mdash;both programs gave out similar prizes for building personal projects.
      </div>
    </div>
    <div class="faq-section__item" data-action="click->faq-accordion#toggle">
      <span class="faq-section__number">6.</span>
      <span class="faq-section__question">I&rsquo;ve got more questions...</span>
      <span class="faq-section__arrow" data-faq-accordion-target="arrow">&#9654;</span>
      <div class="faq-section__answer" data-faq-accordion-target="answer">
        You can email us at <%= mail_to "stardance@hackclub.com" %>! We&rsquo;ll try and respond to everything within two days :)
      </div>
    </div>
  </div>
</section>
